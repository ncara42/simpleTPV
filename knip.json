{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["**/postcss.config.js"],
  "workspaces": {
    ".": {},
    "apps/api": {
      "ignoreDependencies": ["@prisma/client", "pg"],
      "vitest": {
        "config": ["vitest.config.ts", "vitest.integration.config.ts"],
        "entry": ["test/**/*.integration.spec.ts", "test/global-setup.ts", "test/helpers/**/*.ts"]
      }
    },
    "packages/db": {
      "ignoreDependencies": ["@prisma/client", "@prisma/client-runtime-utils", "pg", "@types/pg"]
    },
    "apps/tpv": {
      "playwright": {
        "config": ["playwright.config.ts"],
        "entry": ["e2e/**/*.spec.ts", "e2e/**/*.setup.ts"]
      }
    },
    "apps/backoffice": {
      "playwright": {
        "config": ["playwright.config.ts"],
        "entry": ["e2e/**/*.spec.ts", "e2e/**/*.setup.ts"]
      }
    }
  }
}
