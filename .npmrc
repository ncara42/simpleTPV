strict-peer-dependencies=true
auto-install-peers=true
engine-strict=true
shamefully-hoist=false

# pnpm 11 trata ignored builds como error fatal por defecto (strict-dep-builds=true).
# Los paquetes con scripts (@nestjs/core, @prisma/*, @swc/core, esbuild, prisma)
# están listados en pnpm-workspace.yaml onlyBuiltDependencies. Aún así, en CI con
# --frozen-lockfile pnpm puede reportar build scripts ignorados (subdependencias
# transitivas con versiones distintas). Desactivamos el modo strict para no
# bloquear install. Las builds reales siguen ejecutándose para los listados.
strict-dep-builds=false
