# Postgres local (docker compose up -d postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=simpletpv

# Prisma migrate/seed usa este (superuser).
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/simpletpv?schema=public

# Lookup de login/refresh (rol app_admin con BYPASSRLS). Login y refresh ocurren
# ANTES de conocer el tenant, por lo que necesitan bypassar RLS para buscar usuarios
# por email. Si no se define, cae a DATABASE_URL (rol `app`) y login siempre falla.
DATABASE_URL_AUTH=postgresql://app_admin:app_admin_dev_password@localhost:5434/simpletpv

# API runtime usa este (rol app con RLS aplicada).
# Para que esta URL funcione, el rol `app` necesita LOGIN+PASSWORD. Ejecuta:
#   pnpm --filter @simpletpv/db db:bootstrap-dev
# UNA VEZ tras el primer `prisma migrate deploy`. En producción NO se ejecuta
# ese script — Dokploy aplica ALTER ROLE manualmente con un secret real.
# Ver packages/db/scripts/README.md.
DATABASE_URL_APP=postgresql://app:app_dev_password@localhost:5434/simpletpv?schema=public

# Migraciones en el deploy (#78). Rol con privilegios DDL (owner) que aplica
# `prisma migrate deploy` en el arranque del contenedor (apps/api/docker-entrypoint.sh).
# Separado del rol de runtime DATABASE_URL_APP (que tiene RLS y no puede hacer DDL).
# En local apunta al superuser; en producción se configura en Dokploy. Ver docs/deployment.md.
DATABASE_URL_MIGRATE=postgresql://postgres:postgres@localhost:5434/simpletpv?schema=public

# Redis para el cache de consultas de stock (#28). docker compose up -d redis.
# El cache es una optimización: si Redis no responde, la API degrada a Postgres
# sin romper (con un warning). En producción Dokploy provee dokploy-redis.
REDIS_URL=redis://localhost:6381

# Endurecimiento de seguridad (#72).
# CORS: orígenes permitidos (CSV). Sin definir → orígenes de dev (5173/5174/4173/4174).
# En producción: dominios reales del backoffice y el TPV.
# CORS_ORIGINS=https://backoffice.tudominio.com,https://tpv.tudominio.com
# Rate limiting global por IP (el login se restringe aparte a 5/min).
THROTTLE_TTL=60000
THROTTLE_LIMIT=120
# Máximo de conexiones SSE (/events) concurrentes por usuario y réplica (SEC-03).
# Cada SSE abre una conexión Redis dedicada; este tope corta el agotamiento.
SSE_MAX_CONNECTIONS_PER_USER=5
# Saltos de proxy de confianza para `trust proxy` (req.ip real tras el proxy, SEC-08).
# 1 = un nginx delante (default). 0 = sin proxy (no confiar en X-Forwarded-For).
TRUST_PROXY_HOPS=1

# Monitorización de errores (#79). Sin DSN → Sentry inactivo (la app funciona igual).
# Solo se activa en producción (NODE_ENV=production en la API, build PROD en los frontends).
# DSN agnóstico: vale para sentry.io (SaaS) o una instancia self-hosted. Ver docs/observability-sentry.md.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# Frontends — Vite solo expone variables con prefijo VITE_:
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production

# Chatbot del dashboard (#188). Sin ninguna clave → el chatbot queda DESHABILITADO:
# `GET /chat/models` devuelve [] y el panel muestra el aviso "IA no configurada" en vez del
# input. Basta con definir UNA de las dos para activarlo (cada proveedor aporta sus modelos).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
