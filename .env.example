# Postgres local (docker compose up -d postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=simpletpv

# Prisma migrate/seed usa este (superuser).
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/simpletpv?schema=public

# API runtime usa este (rol app con RLS aplicada).
# Para que esta URL funcione, el rol `app` necesita LOGIN+PASSWORD. Ejecuta:
#   pnpm --filter @simpletpv/db db:bootstrap-dev
# UNA VEZ tras el primer `prisma migrate deploy`. En producción NO se ejecuta
# ese script — Dokploy aplica ALTER ROLE manualmente con un secret real.
# Ver packages/db/scripts/README.md.
DATABASE_URL_APP=postgresql://app:app_dev_password@localhost:5434/simpletpv?schema=public

# Redis para el cache de consultas de stock (#28). docker compose up -d redis.
# El cache es una optimización: si Redis no responde, la API degrada a Postgres
# sin romper (con un warning). En producción Dokploy provee dokploy-redis.
REDIS_URL=redis://localhost:6381
