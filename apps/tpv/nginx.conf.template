server {
    listen 8080;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    # Cabeceras de seguridad del documento SPA (A-06). El accessToken vive en
    # localStorage, así que una CSP estricta limita su exfiltración ante un XSS:
    # script-src 'self' impide cargar JS externo y connect-src acota a dónde se
    # puede enviar. style-src admite 'unsafe-inline' porque React/Recharts inyectan
    # estilos inline (no ejecuta JS). Sentry SaaS necesita connect-src a
    # *.ingest.sentry.io (ajustar si se usa Sentry self-hosted). Se define como
    # variable para reutilizarla en location = /index.html, cuyo add_header propio
    # rompería la herencia de estas cabeceras.
    set $csp "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://*.ingest.sentry.io https://*.ingest.de.sentry.io";
    add_header Content-Security-Policy $csp always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Proxy a la API: /api/* -> ${API_URL}/* (quita el prefijo /api, igual que el dev proxy de Vite).
    # Resolver de Docker (127.0.0.11) + variable en proxy_pass => la resolución DNS del upstream
    # ocurre por petición, no al arrancar, así nginx levanta aunque la API aún no esté lista.
    location ~ ^/api/(.*)$ {
        resolver 127.0.0.11 valid=10s ipv6=off;
        set $upstream ${API_URL};
        proxy_pass $upstream/$1$is_args$args;
        # Host del upstream (no el Host del cliente, que es manipulable).
        proxy_set_header Host $proxy_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    location = /index.html {
        add_header Cache-Control "no-cache";
        # Repetidas porque un add_header en el location anula la herencia del server.
        add_header Content-Security-Policy $csp always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    }
    location /assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
    }
}
