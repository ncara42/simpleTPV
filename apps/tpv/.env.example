# Modo demo del TPV. Default = true (datos demo, sin backend necesario).
# Pon VITE_DEMO_MODE=false para cablear la API real (el proxy /api → :3001 ya está
# configurado en packages/web-config/vite.base.ts para dev y preview).
VITE_DEMO_MODE=true

# Observabilidad (opcional, solo build de producción).
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production

# URL del backoffice para el toggle TPV/Backoffice (opcional).
# VITE_BACKOFFICE_URL=http://localhost:5174
