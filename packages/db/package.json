{
  "name": "@simpletpv/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./generated/client/index.js",
  "types": "./generated/client/index.d.ts",
  "scripts": {
    "build": "prisma generate",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:bootstrap-dev": "docker compose -f ../../docker-compose.yml exec -T postgres psql -U postgres -d simpletpv -f - < scripts/dev-bootstrap.sql"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^3.0.0",
    "dotenv": "^16.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.0.0",
    "prisma": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0"
  }
}
