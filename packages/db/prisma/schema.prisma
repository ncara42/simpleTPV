generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  nif       String?  @unique
  country   String   @default("ES")
  locale    String   @default("es-ES")
  currency  String   @default("EUR")
  createdAt DateTime @default(now())

  stores          Store[]
  users           User[]
  products        Product[]
  productFamilies ProductFamily[]
  auditLogs       AuditLog[]
  sales           Sale[]
  saleLines       SaleLine[]
  cashSessions    CashSession[]
  returns         Return[]
  returnLines     ReturnLine[]
  stock           Stock[]
  stockMovements  StockMovement[]
  stockAlerts     StockAlert[]
}

model Store {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  address        String?
  active         Boolean  @default(true)
  code           String
  ticketCounter  Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  users        UserStore[]
  sales        Sale[]
  cashSessions CashSession[]
  returns      Return[]
  stock          Stock[]
  stockMovements StockMovement[]
  stockAlerts    StockAlert[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  email          String   @unique
  name           String
  passwordHash   String
  pinHash        String?
  role           UserRole
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  stores       UserStore[]
  sales        Sale[]
  cashSessions CashSession[]
  returns      Return[]
  stockMovements StockMovement[]

  @@index([organizationId])
}

model UserStore {
  userId  String @db.Uuid
  storeId String @db.Uuid

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@id([userId, storeId])
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  familyId       String?  @db.Uuid
  name           String
  description    String?
  barcode        String?
  sku            String?
  saleUnit       SaleUnit @default(UNIT)
  unitSymbol     String   @default("ud")
  salePrice      Decimal  @db.Decimal(10, 4)
  costPrice      Decimal  @default(0) @db.Decimal(10, 4)
  taxRate        Decimal  @default(21) @db.Decimal(5, 2)
  imageUrl       String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  family       ProductFamily? @relation(fields: [familyId], references: [id])
  saleLines    SaleLine[]
  returnLines  ReturnLine[]
  stock          Stock[]
  stockMovements StockMovement[]
  stockAlerts    StockAlert[]

  @@index([organizationId, active])
  @@index([organizationId, barcode])
  @@index([organizationId, familyId])
}

model ProductFamily {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  parentId       String?  @db.Uuid
  name           String
  color          String?
  icon           String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  parent       ProductFamily?  @relation("FamilyHierarchy", fields: [parentId], references: [id])
  children     ProductFamily[] @relation("FamilyHierarchy")
  products     Product[]

  @@index([organizationId, parentId])
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userId         String?  @db.Uuid
  action         String
  entity         String
  entityId       String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
}

model Sale {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  storeId        String   @db.Uuid
  userId         String   @db.Uuid
  ticketNumber   String
  subtotal       Decimal       @db.Decimal(12, 2)
  discountTotal  Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  paymentMethod  PaymentMethod
  cashGiven      Decimal?      @db.Decimal(12, 2)
  cashChange     Decimal?      @db.Decimal(12, 2)
  status         SaleStatus    @default(COMPLETED)
  voidedAt       DateTime?
  voidedBy       String?       @db.Uuid
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  lines        SaleLine[]
  returns      Return[]

  @@unique([organizationId, ticketNumber])
  @@index([organizationId, storeId, createdAt])
}

model SaleLine {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  saleId         String  @db.Uuid
  productId      String  @db.Uuid
  name           String
  unitPrice      Decimal @db.Decimal(10, 4)
  qty            Decimal @db.Decimal(10, 3)
  discountPct    Decimal @default(0) @db.Decimal(5, 2)
  discountAmt    Decimal @default(0) @db.Decimal(12, 2)
  // IVA congelado en el momento de la venta (copiado de product.taxRate) para un
  // desglose histórico fiable aunque el producto cambie de tipo después.
  taxRate        Decimal @default(21) @db.Decimal(5, 2)
  lineTotal      Decimal @db.Decimal(12, 2)

  organization Organization @relation(fields: [organizationId], references: [id])
  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
  returnLines  ReturnLine[]

  @@index([saleId])
}

// Devolución parcial contra un ticket de venta (#15). Cada devolución agrupa
// una o varias líneas (ReturnLine) devueltas de una misma venta. El motivo es
// obligatorio (auditoría). El total se congela en el momento de la devolución.
model Return {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  storeId        String   @db.Uuid
  userId         String   @db.Uuid
  saleId         String   @db.Uuid // venta contra la que se devuelve
  reason         String // motivo obligatorio
  total          Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  sale         Sale         @relation(fields: [saleId], references: [id])
  lines        ReturnLine[]

  @@index([organizationId, saleId])
}

// Línea de una devolución: referencia la SaleLine devuelta y la cantidad. Lleva
// su propio organizationId con RLS propia (mismo patrón que SaleLine). El
// lineTotal es la parte proporcional del neto de la SaleLine, congelada.
model ReturnLine {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid // RLS propia (como SaleLine)
  returnId       String  @db.Uuid
  saleLineId     String  @db.Uuid // línea de venta devuelta
  productId      String  @db.Uuid
  qty            Decimal @db.Decimal(10, 3)
  lineTotal      Decimal @db.Decimal(12, 2)

  organization Organization @relation(fields: [organizationId], references: [id])
  return       Return       @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleLine     SaleLine     @relation(fields: [saleLineId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@index([returnId])
}

// Stock actual de un producto en una tienda. Cantidad en Decimal(12,3) para
// soportar productos a granel (peso/volumen). minStock es el umbral de alerta.
// RLS por tenant (organizationId con policy propia). Una fila por par
// producto+tienda (@@unique).
model Stock {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  productId      String   @db.Uuid
  storeId        String   @db.Uuid
  quantity       Decimal  @default(0) @db.Decimal(12, 3)
  minStock       Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])

  @@unique([productId, storeId])
  @@index([organizationId, storeId])
}

// Movimiento de stock: cada entrada/salida deja rastro auditado. quantity es
// positivo (entrada) o negativo (salida). referenceId apunta al documento que lo
// originó (saleId, returnId, transferId...). RLS por tenant.
model StockMovement {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  productId      String       @db.Uuid
  storeId        String       @db.Uuid
  userId         String?      @db.Uuid
  type           MovementType
  quantity       Decimal      @db.Decimal(12, 3)
  referenceId    String?      @db.Uuid
  reason         String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, productId, createdAt])
  @@index([organizationId, storeId, createdAt])
}

// Alerta de stock bajo/agotado de un producto en una tienda. Se genera/resuelve
// automáticamente dentro del flujo del movimiento (no por un cron). Una sola
// alerta activa (resolved=false) por par producto+tienda (índice único parcial
// definido en SQL en la migración). RLS por tenant.
model StockAlert {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  productId      String    @db.Uuid
  storeId        String    @db.Uuid
  alertType      AlertType
  resolved       Boolean   @default(false)
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])

  @@index([organizationId, resolved, createdAt])
}

model CashSession {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  storeId        String            @db.Uuid
  userId         String            @db.Uuid // quién abrió la caja
  openingAmount  Decimal           @db.Decimal(12, 2)
  closingAmount  Decimal?          @db.Decimal(12, 2) // efectivo contado al cerrar
  expectedAmount Decimal?          @db.Decimal(12, 2) // inicial + ventas efectivo del turno
  difference     Decimal?          @db.Decimal(12, 2) // closingAmount - expectedAmount
  status         CashSessionStatus @default(OPEN)
  openedAt       DateTime          @default(now())
  closedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, storeId, status])
  // Índice único parcial "una sola caja OPEN por tienda" definido en SQL en la
  // migración (Prisma no soporta partial unique indexes en el schema).
}

enum SaleUnit {
  UNIT
  WEIGHT
  VOLUME
  LENGTH
}

enum PaymentMethod {
  CASH
  CARD
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum UserRole {
  ADMIN
  MANAGER
  CLERK
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum MovementType {
  SALE
  RETURN
  TRANSFER_IN
  TRANSFER_OUT
  PURCHASE_RECEIPT
  ADJUSTMENT
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
}
