generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  nif       String?  @unique
  country   String   @default("ES")
  locale    String   @default("es-ES")
  currency  String   @default("EUR")
  createdAt DateTime @default(now())

  stores             Store[]
  users              User[]
  products           Product[]
  productFamilies    ProductFamily[]
  auditLogs          AuditLog[]
  sales              Sale[]
  saleLines          SaleLine[]
  cashSessions       CashSession[]
  cashMovements      CashMovement[]
  officialDevices    OfficialDevice[]
  timeClockEntries   TimeClockEntry[]
  returns            Return[]
  returnLines        ReturnLine[]
  stock              Stock[]
  stockMovements     StockMovement[]
  stockAlerts        StockAlert[]
  transfers          Transfer[]
  transferLines      TransferLine[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  purchaseOrderLines PurchaseOrderLine[]
  verifactuRecords   VerifactuRecord[]
  salesExports       SalesExport[]
  userPreferences    UserPreference[]
}

// Personalización por usuario (IT-16): preferencias clave-valor (JSON) por usuario.
// Cada fila es un ámbito ('dashboard.cards', 'table.sales.columns', 'defaults'…) con
// su valor JSON. RLS por tenant; el servicio acota además a req.user (cada uno solo
// ve/edita las suyas).
model UserPreference {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userId         String   @db.Uuid
  key            String
  value          Json
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([organizationId, userId])
}

model Store {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  address        String?
  active         Boolean  @default(true)
  code           String
  ticketCounter  Int      @default(0)
  createdAt      DateTime @default(now())

  organization     Organization     @relation(fields: [organizationId], references: [id])
  users            UserStore[]
  sales            Sale[]
  cashSessions     CashSession[]
  cashMovements    CashMovement[]
  returns          Return[]
  stock            Stock[]
  stockMovements   StockMovement[]
  stockAlerts      StockAlert[]
  officialDevices  OfficialDevice[]
  timeClockEntries TimeClockEntry[]
  transfersOut     Transfer[]       @relation("TransferOrigin")
  transfersIn      Transfer[]       @relation("TransferDest")
  purchaseOrders   PurchaseOrder[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  email          String   @unique
  name           String
  passwordHash   String
  pinHash        String?
  role           UserRole
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization     Organization     @relation(fields: [organizationId], references: [id])
  stores           UserStore[]
  sales            Sale[]
  cashSessions     CashSession[]
  cashMovements    CashMovement[]
  returns          Return[]
  stockMovements   StockMovement[]
  timeClockEntries TimeClockEntry[]
  refreshTokens    RefreshToken[]
  preferences      UserPreference[]

  @@index([organizationId])
}

// Sesiones de refresh (SEC-06): un registro por refresh token emitido (id = jti
// del JWT). La rotación marca usedAt y emite uno nuevo en la misma familia; si se
// presenta un token ya usado (reuso → robo), se revoca toda la familia. La
// EXPIRACIÓN la valida el propio JWT (exp); aquí solo vive el estado de rotación.
// Se accede solo desde el flujo de auth con el rol app_admin (BYPASSRLS), porque
// login/refresh corren sin contexto de tenant.
model RefreshToken {
  id             String    @id @db.Uuid // = jti del refresh JWT
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  familyId       String    @db.Uuid
  usedAt         DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([familyId])
  @@index([userId])
}

model UserStore {
  userId  String @db.Uuid
  storeId String @db.Uuid

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@id([userId, storeId])
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  familyId       String?  @db.Uuid
  name           String
  description    String?
  barcode        String?
  sku            String?
  saleUnit       SaleUnit @default(UNIT)
  unitSymbol     String   @default("ud")
  salePrice      Decimal  @db.Decimal(10, 4)
  costPrice      Decimal  @default(0) @db.Decimal(10, 4)
  taxRate        Decimal  @default(21) @db.Decimal(5, 2)
  imageUrl       String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id])
  family             ProductFamily?      @relation(fields: [familyId], references: [id])
  saleLines          SaleLine[]
  returnLines        ReturnLine[]
  stock              Stock[]
  stockMovements     StockMovement[]
  stockAlerts        StockAlert[]
  transferLines      TransferLine[]
  purchaseOrderLines PurchaseOrderLine[]

  @@index([organizationId, active])
  @@index([organizationId, barcode])
  @@index([organizationId, familyId])
}

model ProductFamily {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  parentId       String?  @db.Uuid
  name           String
  color          String?
  icon           String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  parent       ProductFamily?  @relation("FamilyHierarchy", fields: [parentId], references: [id])
  children     ProductFamily[] @relation("FamilyHierarchy")
  products     Product[]

  @@index([organizationId, parentId])
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userId         String?  @db.Uuid
  action         String
  entity         String
  entityId       String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
}

model Sale {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  storeId        String        @db.Uuid
  userId         String        @db.Uuid
  ticketNumber   String
  subtotal       Decimal       @db.Decimal(12, 2)
  discountTotal  Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  paymentMethod  PaymentMethod
  cashGiven      Decimal?      @db.Decimal(12, 2)
  cashChange     Decimal?      @db.Decimal(12, 2)
  status         SaleStatus    @default(COMPLETED)
  voidedAt       DateTime?
  voidedBy       String?       @db.Uuid
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  lines        SaleLine[]
  returns      Return[]

  @@unique([organizationId, ticketNumber])
  @@index([organizationId, storeId, createdAt])
}

model SaleLine {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  saleId         String  @db.Uuid
  productId      String  @db.Uuid
  name           String
  unitPrice      Decimal @db.Decimal(10, 4)
  qty            Decimal @db.Decimal(10, 3)
  discountPct    Decimal @default(0) @db.Decimal(5, 2)
  discountAmt    Decimal @default(0) @db.Decimal(12, 2)
  // IVA congelado en el momento de la venta (copiado de product.taxRate) para un
  // desglose histórico fiable aunque el producto cambie de tipo después.
  taxRate        Decimal @default(21) @db.Decimal(5, 2)
  // Coste unitario del producto congelado en el momento de la venta (copiado de
  // product.costPrice) para una rentabilidad histórica fiable aunque el coste
  // cambie después (IT-03). Antes el margen se calculaba con el coste ACTUAL.
  costPrice      Decimal @default(0) @db.Decimal(10, 4)
  // Origen del descuento de la línea: VOLUNTARY (manual del vendedor) o PROMOTION
  // (regla programada). Hoy todos los descuentos son manuales → default VOLUNTARY.
  // Permite analizar el descuento voluntario por empleado (STAT-04) sin re-migrar.
  discountSource DiscountSource @default(VOLUNTARY)
  lineTotal      Decimal @db.Decimal(12, 2)

  organization Organization @relation(fields: [organizationId], references: [id])
  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
  returnLines  ReturnLine[]

  @@index([saleId])
  @@index([organizationId, productId])
}

// Devolución parcial contra un ticket de venta (#15). Cada devolución agrupa
// una o varias líneas (ReturnLine) devueltas de una misma venta. El motivo es
// obligatorio (auditoría). El total se congela en el momento de la devolución.
model Return {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  storeId        String   @db.Uuid
  userId         String   @db.Uuid
  // Venta contra la que se devuelve. NULL en devoluciones SIN ticket (#59),
  // que requieren autorización por PIN de un MANAGER/ADMIN (authorizedBy).
  saleId         String?  @db.Uuid
  authorizedBy   String?  @db.Uuid // MANAGER/ADMIN que autorizó (devolución sin ticket)
  reason         String // motivo obligatorio
  total          Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  sale         Sale?        @relation(fields: [saleId], references: [id])
  lines        ReturnLine[]

  @@index([organizationId, saleId])
}

// Línea de una devolución: referencia la SaleLine devuelta y la cantidad. Lleva
// su propio organizationId con RLS propia (mismo patrón que SaleLine). El
// lineTotal es la parte proporcional del neto de la SaleLine, congelada.
model ReturnLine {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid // RLS propia (como SaleLine)
  returnId       String  @db.Uuid
  // Línea de venta devuelta. NULL en devoluciones SIN ticket (#59): no hay
  // SaleLine de referencia; el importe se calcula del precio actual del producto.
  saleLineId     String? @db.Uuid
  productId      String  @db.Uuid
  qty            Decimal @db.Decimal(10, 3)
  lineTotal      Decimal @db.Decimal(12, 2)

  organization Organization @relation(fields: [organizationId], references: [id])
  return       Return       @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleLine     SaleLine?    @relation(fields: [saleLineId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@index([returnId])
}

// Stock actual de un producto en una tienda. Cantidad en Decimal(12,3) para
// soportar productos a granel (peso/volumen). minStock es el umbral de alerta.
// RLS por tenant (organizationId con policy propia). Una fila por par
// producto+tienda (@@unique).
model Stock {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  productId      String   @db.Uuid
  storeId        String   @db.Uuid
  quantity       Decimal  @default(0) @db.Decimal(12, 3)
  minStock       Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])

  @@unique([productId, storeId])
  @@index([organizationId, storeId])
}

// Movimiento de stock: cada entrada/salida deja rastro auditado. quantity es
// positivo (entrada) o negativo (salida). referenceId apunta al documento que lo
// originó (saleId, returnId, transferId...). RLS por tenant.
model StockMovement {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  productId      String       @db.Uuid
  storeId        String       @db.Uuid
  userId         String?      @db.Uuid
  type           MovementType
  quantity       Decimal      @db.Decimal(12, 3)
  referenceId    String?      @db.Uuid
  reason         String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, productId, createdAt])
  @@index([organizationId, storeId, createdAt])
  @@index([organizationId, storeId, type, createdAt])
}

// Alerta de stock bajo/agotado de un producto en una tienda. Se genera/resuelve
// automáticamente dentro del flujo del movimiento (no por un cron). Una sola
// alerta activa (resolved=false) por par producto+tienda (índice único parcial
// definido en SQL en la migración). RLS por tenant.
model StockAlert {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  productId      String    @db.Uuid
  storeId        String    @db.Uuid
  alertType      AlertType
  resolved       Boolean   @default(false)
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])

  @@index([organizationId, resolved, createdAt])
}

// Traspaso de mercancía entre dos tiendas del tenant (#31). Flujo de estados
// DRAFT → SENT (decrementa origen) → RECEIVED (incrementa destino) → CLOSED.
// RLS por tenant. originStoreId != destStoreId (validado en el servicio).
model Transfer {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  originStoreId  String         @db.Uuid
  destStoreId    String         @db.Uuid
  status         TransferStatus @default(DRAFT)
  notes          String?
  createdBy      String         @db.Uuid
  createdAt      DateTime       @default(now())
  sentAt         DateTime?
  receivedAt     DateTime?
  closedAt       DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id])
  originStore  Store          @relation("TransferOrigin", fields: [originStoreId], references: [id])
  destStore    Store          @relation("TransferDest", fields: [destStoreId], references: [id])
  lines        TransferLine[]

  @@index([organizationId, status, createdAt])
}

// Línea de un traspaso: cantidad enviada y, tras la recepción, cantidad recibida
// y discrepancia (recibido - enviado, puede ser negativa por merma en tránsito).
// RLS propia (organizationId con policy, igual que SaleLine/ReturnLine).
model TransferLine {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid
  transferId       String   @db.Uuid
  productId        String   @db.Uuid
  quantitySent     Decimal  @db.Decimal(12, 3)
  quantityReceived Decimal? @db.Decimal(12, 3)
  discrepancy      Decimal? @db.Decimal(12, 3)
  discrepancyNote  String?

  organization Organization @relation(fields: [organizationId], references: [id])
  transfer     Transfer     @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@index([transferId])
}

// Proveedor de mercancía (#44). leadTimeDays es el plazo de entrega estimado,
// usado de base para los KPIs y la propuesta de pedido. RLS por tenant.
model Supplier {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  nif            String?
  email          String?
  phone          String?
  leadTimeDays   Int      @default(7)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([organizationId, active])
}

// Pedido a proveedor (#44). Flujo de estados DRAFT → CONFIRMED →
// PARTIALLY_RECEIVED → RECEIVED. storeId es el destino (tienda/almacén). RLS.
model PurchaseOrder {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @db.Uuid
  supplierId     String              @db.Uuid
  storeId        String              @db.Uuid
  status         PurchaseOrderStatus @default(DRAFT)
  notes          String?
  createdBy      String              @db.Uuid
  createdAt      DateTime            @default(now())
  confirmedAt    DateTime?
  receivedAt     DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id])
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  store        Store               @relation(fields: [storeId], references: [id])
  lines        PurchaseOrderLine[]

  @@index([organizationId, status, createdAt])
}

// Línea de un pedido: cantidad pedida, recibida (acumulada en recepciones
// sucesivas) y coste unitario. RLS propia (organizationId con policy).
model PurchaseOrderLine {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @db.Uuid
  purchaseOrderId  String   @db.Uuid
  productId        String   @db.Uuid
  quantityOrdered  Decimal  @db.Decimal(12, 3)
  quantityReceived Decimal  @default(0) @db.Decimal(12, 3)
  unitCost         Decimal? @db.Decimal(10, 4)

  organization  Organization  @relation(fields: [organizationId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
}

// Registro de facturación VeriFactu (#47). Uno por venta/devolución. Los
// registros del mismo tenant forman una cadena inalterable vía previousHash →
// hash. Se envía a la AEAT (vía proveedor certificado) por una cola con
// reintentos; status refleja el resultado. RLS por tenant.
model VerifactuRecord {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  saleId         String?         @db.Uuid
  returnId       String?         @db.Uuid
  type           VerifactuType
  status         VerifactuStatus @default(PENDING)
  hash           String // huella SHA-256 de este registro
  previousHash   String? // huella del registro anterior del tenant (encadenamiento)
  qrData         String? // URL de cotejo AEAT para el ticket
  payload        Json // datos del registro (importe, fecha, nif...)
  attempts       Int             @default(0)
  lastError      String?
  sentAt         DateTime?
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status, createdAt])
  @@index([organizationId, createdAt])
}

// Export asíncrono del historial de ventas a CSV (IT-05). Se pide con unos filtros
// (los mismos que el listado), se encola un job que genera el CSV en background y
// el resultado (csv + estado) se guarda aquí — así la UI no se bloquea. RLS por tenant.
model SalesExport {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  status         SalesExportStatus @default(PENDING)
  filters        Json // filtros con los que se pidió (storeId, rango, vendedor, familia, estado, q)
  rowCount       Int? // nº de ventas exportadas (cuando COMPLETED)
  csv            String? // contenido CSV generado (cuando COMPLETED)
  error          String? // mensaje de error (cuando FAILED)
  requestedById  String            @db.Uuid // usuario que pidió el export
  createdAt      DateTime          @default(now())
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status, createdAt])
}

enum SalesExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model CashSession {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  storeId        String            @db.Uuid
  userId         String            @db.Uuid // quién abrió la caja
  openingAmount  Decimal           @db.Decimal(12, 2)
  closingAmount  Decimal?          @db.Decimal(12, 2) // efectivo contado al cerrar
  expectedAmount Decimal?          @db.Decimal(12, 2) // inicial + ventas efectivo del turno
  difference     Decimal?          @db.Decimal(12, 2) // closingAmount - expectedAmount
  status         CashSessionStatus @default(OPEN)
  openedAt       DateTime          @default(now())
  closedAt       DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id])
  store        Store          @relation(fields: [storeId], references: [id])
  user         User           @relation(fields: [userId], references: [id])
  movements    CashMovement[]
  // Índice único parcial "una sola caja OPEN por tienda" definido en SQL en la
  // migración (Prisma no soporta partial unique indexes en el schema).

  @@index([organizationId, storeId, status])
}

model CashMovement {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  cashSessionId  String           @db.Uuid
  storeId        String           @db.Uuid
  userId         String           @db.Uuid
  type           CashMovementType
  amount         Decimal          @db.Decimal(12, 2)
  reason         String
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  cashSession  CashSession  @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, cashSessionId, createdAt])
  @@index([organizationId, storeId, createdAt])
}

model OfficialDevice {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  storeId        String    @db.Uuid
  name           String
  pairingToken   String    @unique
  authorized     Boolean   @default(false)
  pairedAt       DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])

  @@index([organizationId, storeId, authorized])
}

model TimeClockEntry {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  storeId        String        @db.Uuid
  userId         String        @db.Uuid
  deviceId       String?       @db.Uuid
  type           TimeClockType
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, storeId, userId, createdAt])
}

enum SaleUnit {
  UNIT
  WEIGHT
  VOLUME
  LENGTH
}

enum PaymentMethod {
  CASH
  CARD
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum DiscountSource {
  VOLUNTARY
  PROMOTION
}

enum UserRole {
  ADMIN
  MANAGER
  CLERK
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  IN
  OUT
}

enum TimeClockType {
  CLOCK_IN
  CLOCK_OUT
  BREAK_START
  BREAK_END
}

enum MovementType {
  SALE
  RETURN
  TRANSFER_IN
  TRANSFER_OUT
  PURCHASE_RECEIPT
  ADJUSTMENT
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
}

enum TransferStatus {
  DRAFT
  SENT
  RECEIVED
  CLOSED
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
}

enum VerifactuType {
  INVOICE
  RECTIFICATION
}

enum VerifactuStatus {
  PENDING
  SENT
  FAILED
}
