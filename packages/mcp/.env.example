# ─── SimpleTpv MCP ────────────────────────────────────────────────────────────
# Servidor MCP remoto multi-tenant con OAuth 2.1. Cada usuario se conecta desde
# Claude (Desktop/web/Code) con SUS credenciales de SimpleTpv; no hay
# credenciales de empresa empotradas.

# Transporte: "http" (default, remoto OAuth) | "stdio" (Claude local, 1 usuario)
MCP_TRANSPORT=http

# URL del backend SimpleTpv (Rust)
TPV_API_URL=http://localhost:3001

# ─── Modo http (OAuth 2.1) ──────────────────────────────────────────────────────
# URL pública del servidor (issuer del Authorization Server y base de endpoints).
# DEBE ser https en producción (TLS lo termina el reverse proxy).
MCP_ISSUER_URL=https://mcp.tuempresa.com

# Identificador del recurso protegido (audiencia de los tokens). Por defecto
# `${MCP_ISSUER_URL}/mcp`. Normalmente no hace falta tocarlo.
# MCP_RESOURCE_URL=https://mcp.tuempresa.com/mcp

# Puerto y bind del proceso (detrás del reverse proxy).
MCP_PORT=8766
MCP_BIND=0.0.0.0

# Clave de firma de los access tokens del MCP (JWK privada EC P-256, en una línea).
# Generar con:  node -e "import('jose').then(async j=>{const{privateKey}=await j.generateKeyPair('ES256',{extractable:true});const k=await j.exportJWK(privateKey);k.kid='mcp-'+Date.now();console.log(JSON.stringify(k))})"
# Si falta, se genera una efímera (los tokens mueren al reiniciar) — NO en producción.
MCP_JWT_PRIVATE_JWK=

# Clave para cifrar en reposo la sesión de backend de cada usuario (AES-256-GCM).
# Generar con:  openssl rand -base64 32
# Si falta, se usa una efímera (las sesiones no sobreviven al reinicio) — NO en producción.
MCP_ENC_KEY=

# Estado OAuth en Redis (durable y multi-instancia). Sin esto, almacén en memoria
# (solo desarrollo). En producción es obligatorio.
REDIS_URL=redis://localhost:6379

# Orígenes permitidos en CORS (CSV). Recomendado en producción.
MCP_ALLOWED_ORIGINS=https://claude.ai

# Saltos de proxy de confianza para Express (`trust proxy`). OBLIGATORIO en
# producción tras un reverse proxy: si llega `X-Forwarded-For` y esto vale
# `false`, el rate-limiter de /register /token /authorize lanza
# ERR_ERL_UNEXPECTED_X_FORWARDED_FOR → 500 (rompe el registro DCR de Claude).
# Pon el nº de proxies inversos delante del proceso: `1` con un único Traefik
# (Cloudflare→cloudflared→Traefik→app). NO uses `true` (permisivo, permite
# spoofing del IP de cliente). Default `false` (local sin proxy).
MCP_TRUST_PROXY=1

# ─── Modo stdio (Claude local, sin OAuth) ───────────────────────────────────────
# La spec de MCP indica que stdio toma credenciales del entorno (un solo usuario).
# Solo se usan si MCP_TRANSPORT=stdio.
TPV_EMAIL=admin@tuempresa.com
TPV_PASSWORD=tu_password_seguro
