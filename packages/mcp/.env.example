# URL del backend SimpleTpv (ajusta en prod a la URL del VPS)
TPV_API_URL=http://localhost:3001

# Credenciales de un usuario ADMIN o MANAGER
TPV_EMAIL=admin@tuempresa.com
TPV_PASSWORD=tu_password_seguro

# Transporte: "http" (default, para conexiones remotas) | "stdio" (Claude Code/Desktop local)
MCP_TRANSPORT=http

# Puerto del servidor HTTP (solo si MCP_TRANSPORT=http)
MCP_PORT=8766

# Clave de API para proteger el acceso (recomendado en producción)
# Si se define, los clientes deben incluir: Authorization: Bearer <clave>
MCP_API_KEY=genera_una_clave_aleatoria_aqui
