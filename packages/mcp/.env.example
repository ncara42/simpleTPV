# URL del backend SimpleTpv
TPV_API_URL=http://localhost:3001

# Credenciales de un usuario ADMIN o MANAGER
TPV_EMAIL=admin@tuempresa.com
TPV_PASSWORD=tu_password_seguro

# Transporte: "http" (default, para conexiones remotas) | "stdio" (Claude Code/Desktop local)
MCP_TRANSPORT=http

# Puerto del servidor HTTP
MCP_PORT=8766

# [REQUERIDO para MCP_TRANSPORT=http] Clave de API de acceso
# Genera una con: openssl rand -hex 32
MCP_API_KEY=

# Dirección de bind (default: 127.0.0.1 — solo local)
# Cambia a 0.0.0.0 para exponer en red; asegúrate de tener TLS en el reverse proxy.
MCP_BIND=0.0.0.0

# Dominio público del servidor (usado para validar el header Host y mitigar DNS rebinding)
# Ejemplo: mcp.tuempresa.com
MCP_PUBLIC_HOST=

# Orígenes permitidos en CORS (CSV). Recomendado en producción.
# Ejemplo: https://claude.ai,https://tu-backoffice.com
MCP_ALLOWED_ORIGINS=https://claude.ai
